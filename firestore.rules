rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidCrypto(data) {
      return data.keys().hasAll(['name', 'symbol', 'price', 'image', 'change24h', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.symbol is string && data.symbol.size() > 0 && data.symbol.size() <= 10
        && data.price is number
        && data.image is string && data.image.size() <= 500
        && data.change24h is string && data.change24h.size() <= 10;
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['name', 'email', 'createdAt', 'password'])
        && request.resource.data.email == userId; // Assuming email is doc ID
      allow update: if isOwner(userId) 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'password']);
    }

    // Cryptos
    match /cryptos/{cryptoId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCrypto(request.resource.data);
      allow update: if isSignedIn() && isValidCrypto(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['price', 'change24h']);
    }
  }
}
